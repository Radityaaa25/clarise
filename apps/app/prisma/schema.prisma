// Prisma Schema for Clarise — AI-Powered Learning Platform
// Database: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  PREMIUM_YEARLY
  PREMIUM_TRIAL
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum CourseVisibility {
  PUBLIC
  PRIVATE
}

enum UserActivityType {
  COURSE_VIEW
  MODULE_COMPLETE
  AI_CHAT
  LOGIN
}

enum NotificationType {
  STREAK_REMINDER
  SUBSCRIPTION_EXPIRING
  BADGE_EARNED
  ANNOUNCEMENT
}

enum SourceType {
  DOCUMENTATION
  ARTICLE
  YOUTUBE
  BOOK
  OTHER
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model User {
  id                   String      @id @default(cuid())
  clerkId              String      @unique
  email                String      @unique
  name                 String?
  imageUrl             String?
  role                 UserRole    @default(USER)
  onboardingCompleted  Boolean     @default(false)
  welcomeNotifSent     Boolean     @default(false)
  welcomePopupShown    Boolean     @default(false)
  learningGoal         String?
  currentLevel         Difficulty?
  dailyHours           Int?
  referralCode         String?     @unique
  referredBy           String?
  aiPreferences        Json?
  xp                   Int         @default(0)
  level                Int         @default(1)
  currentStreak        Int         @default(0)
  longestStreak        Int         @default(0)
  streakProtectionUsed Int         @default(0)
  lastActiveDate       DateTime?
  gracePeriodEnd       DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  progress           UserProgress[]
  badges             UserBadge[]
  subscription       Subscription?
  ratings            CourseRating[]
  createdCourses     Course[]             @relation("CourseAuthor")
  notifications      Notification[]
  activities         UserActivity[]
  referrerLogs       ReferralLog[]        @relation("ReferrerLogs")
  referredLogs       ReferralLog[]        @relation("ReferredLogs")
  aiChatHistory      AiChatHistory[]
  dailyReminder      DailyReminder?
  voucherRedemption  VoucherRedemption?
  reports            Report[]
  transactions       Transaction[]
  appFeedback        AppFeedback[]

  @@index([clerkId])
  @@index([email])
  @@index([referralCode])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  courses Course[]

  @@index([slug])
}

model Course {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String?
  categoryId      String
  difficulty      Difficulty       @default(BEGINNER)
  totalModules    Int              @default(0)
  isUserGenerated Boolean          @default(false)
  isPrivate       Boolean          @default(false)
  visibility      CourseVisibility  @default(PUBLIC)
  language        String           @default("id")
  isPublished     Boolean          @default(false)
  isPremium       Boolean          @default(false)
  authorId        String?
  rating          Float            @default(0)
  ratingCount     Int              @default(0)
  isAiGenerated   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  category Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User?           @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  modules  Module[]
  progress UserProgress[]
  ratings  CourseRating[]
  reports  Report[]

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
  @@index([visibility])
}

model Module {
  id        String   @id @default(cuid())
  title     String
  slug      String
  courseId   String
  order     Int      @default(0)
  xpReward  Int      @default(10)
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slides   Slide[]
  progress UserProgress[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model Slide {
  id       String @id @default(cuid())
  moduleId String
  order    Int    @default(0)
  title    String
  content  Json

  module  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sources Source[]

  @@index([moduleId])
}

model Source {
  id      String     @id @default(cuid())
  slideId String
  type    SourceType @default(OTHER)
  title   String
  url     String

  slide Slide @relation(fields: [slideId], references: [id], onDelete: Cascade)

  @@index([slideId])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  courseId    String
  completedAt DateTime?
  enrolledAt  DateTime  @default(now())
  activeSlide Int       @default(0)
  rating      Int?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([courseId])
  @@index([userId, courseId])
}

model CourseRating {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  condition   String

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  status          SubscriptionStatus @default(ACTIVE)
  plan            SubscriptionPlan   @default(FREE)
  duitkuReference String?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([duitkuReference])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model UserActivity {
  id       String           @id @default(cuid())
  userId   String
  type     UserActivityType
  metadata Json?
  date     DateTime         @default(now())
  duration Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

model ReferralLog {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer User @relation("ReferrerLogs", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredLogs", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
  @@index([referrerId])
}

model AiChatHistory {
  id        String   @id @default(cuid())
  userId    String
  courseId   String?
  moduleId  String?
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, courseId])
}

model DailyReminder {
  id            String   @id @default(cuid())
  userId        String   @unique
  enabled       Boolean  @default(false)
  preferredTime String   @default("08:00")
  channel       String   @default("EMAIL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Voucher {
  id          String              @id @default(cuid())
  code        String              @unique
  type        String
  discountPct Int                 @default(0)
  trialDays   Int                 @default(0)
  maxUses     Int
  usedCount   Int                 @default(0)
  expiresAt   DateTime
  createdAt   DateTime            @default(now())

  redemptions VoucherRedemption[]
}

model VoucherRedemption {
  id         String   @id @default(cuid())
  voucherId  String
  userId     String   @unique
  redeemedAt DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id])
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voucherId, userId])
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String    @db.Text
  target    String    @default("ALL")
  isActive  Boolean   @default(true)
  startAt   DateTime
  endAt     DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id        String       @id @default(cuid())
  courseId  String
  userId    String
  reason    String       @db.Text
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([userId])
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  amount          Int
  method          String            @default("UNKNOWN")
  status          TransactionStatus @default(PENDING)
  plan            SubscriptionPlan
  duitkuReference String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Kritik & saran + rating aplikasi dari user.
// Ditampilkan di landing page (yang isPublished) sebagai social proof.
model AppFeedback {
  id          String   @id @default(cuid())
  userId      String
  rating      Int // 1-5
  message     String?  @db.Text
  authorName  String? // snapshot nama untuk ditampilkan publik
  authorRole  String? // mis. learningGoal user, opsional
  isPublished Boolean  @default(true) // admin bisa unpublish bila perlu
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([isPublished, rating])
  @@index([createdAt])
}
