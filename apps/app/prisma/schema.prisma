// Prisma Schema for Clarise — AI-Powered Learning Platform
// Database: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum UserRole {
  FREE
  PREMIUM
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum SourceType {
  DOCUMENTATION
  ARTICLE
  YOUTUBE
  BOOK
  OTHER
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  clerkId      String   @unique
  email        String   @unique
  name         String?
  imageUrl     String?
  role         UserRole @default(FREE)
  xp           Int      @default(0)
  level        Int      @default(1)
  streak       Int      @default(0)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  progress      UserProgress[]
  badges        UserBadge[]
  subscription  Subscription?
  ratings       CourseRating[]
  createdCourses Course[]      @relation("CourseAuthor")

  @@index([clerkId])
  @@index([email])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  courses Course[]

  @@index([slug])
}

model Course {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  description    String?
  categoryId     String
  difficulty     Difficulty @default(BEGINNER)
  totalModules   Int        @default(0)
  isUserGenerated Boolean   @default(false)
  isPrivate      Boolean    @default(false)
  isPublished    Boolean    @default(false)
  isPremium      Boolean    @default(false)
  authorId       String?
  rating         Float      @default(0)
  ratingCount    Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  category Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User?           @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  modules  Module[]
  progress UserProgress[]
  ratings  CourseRating[]

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
}

model Module {
  id        String   @id @default(cuid())
  title     String
  slug      String
  courseId   String
  order     Int      @default(0)
  xpReward  Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slides   Slide[]
  progress UserProgress[]

  @@unique([courseId, slug])
  @@index([courseId])
}

model Slide {
  id       String @id @default(cuid())
  moduleId String
  order    Int    @default(0)
  title    String
  content  Json   // {type: "text"|"code"|"formula"|"image", body: "...", language?: "js", tooltips?: [{token, explanation}]}

  module  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  sources Source[]

  @@index([moduleId])
}

model Source {
  id      String     @id @default(cuid())
  slideId String
  type    SourceType @default(OTHER)
  title   String
  url     String

  slide Slide @relation(fields: [slideId], references: [id], onDelete: Cascade)

  @@index([slideId])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  moduleId    String
  courseId     String
  completedAt DateTime?
  enrolledAt  DateTime  @default(now())
  activeSlide Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([courseId])
}

model CourseRating {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  rating    Int      // 1-5
  review    String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Badge {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  condition   String

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  status          SubscriptionStatus @default(PENDING)
  tripayReference String?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tripayReference])
}
